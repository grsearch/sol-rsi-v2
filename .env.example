# ==========================================
# SOL RSI Monitor v3 — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC ────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API ───────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── Trading Wallet ────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
# 每次买入的 SOL 数量
TRADE_SIZE_SOL=0.2

# ── Slippage ──────────────────────────────
# 买入滑点（卖出自动翻倍以确保止损成交）
SLIPPAGE_BPS=300

# ── RSI 策略参数 ───────────────────────────
RSI_PERIOD=7          # RSI 计算周期（K线数）
RSI_BUY=30            # RSI 上穿此值 → 买入
RSI_SELL=75           # RSI 超过此值 → 卖出

# ── 买入过滤器 ─────────────────────────────
# 过滤器1：EMA 收敛阈值
# EMA9 与 EMA20 差值 / 当前价 > 此值时禁止买入（趋势发散中不买）
EMA_CONVERGE_PCT=3

# 过滤器2：RSI 底背离回溯窗口
# 在最近此数量的 K 线内寻找上一个 RSI 谷底，要求本次谷底不低于上次
RSI_DIVERGE_BARS=20

# ── 止损 ──────────────────────────────────
# 当前价跌破入场价此百分比 → 立即止损平仓
STOP_LOSS_PCT=20

# ── K线 & 价格轮询 ─────────────────────────
KLINE_INTERVAL_SEC=3  # K线宽度（秒），用于 RSI 计算
PRICE_POLL_SEC=1      # 价格轮询间隔（秒），同时触发止损检查

# ── 监控窗口 ──────────────────────────────
# 代币收录后监控多少分钟，窗口内允许多次买卖
TOKEN_MAX_AGE_MINUTES=10

# ── FDV/LP 门槛 ───────────────────────────
FDV_MIN_USD=15000
LP_MIN_USD=5000

# ── Server ────────────────────────────────
PORT=3001
